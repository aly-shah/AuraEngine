# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your values
# ============================================================

# Supabase (public — safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (publishable key only — safe for frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# App URL
VITE_APP_URL=http://localhost:3000

# ============================================================
# BACKEND SECRETS — Set via: supabase secrets set KEY=value
# DO NOT put these in .env.local
# ============================================================
# GEMINI_API_KEY=AIza...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SENDGRID_API_KEY=SG.xxx
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SITE_URL=https://scaliyo.com
